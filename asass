    modalOverlay.Visible = true
    local targetAlpha = show and 0.6 or 1
    local tInfo = TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    
    local tween = TweenService:Create(modalOverlay, tInfo, {BackgroundTransparency = targetAlpha})
    tween:Play()
    
    if not show then
        tween.Completed:Connect(function()
            if modalOverlay.BackgroundTransparency == 1 then
                modalOverlay.Visible = false
            end
        end)
    end
end

local function startFill()
    fillBar.Size = UDim2.new(0, 0, 1, 0) 
    fillBar.Visible = true
    fillBar.BackgroundTransparency = 0 
    
    local tweenInfo = TweenInfo.new(1.7, Enum.EasingStyle.Quad, Enum.EasingDirection.In) 
    fillTween = TweenService:Create(fillBar, tweenInfo, {Size = UDim2.new(1, 0, 1, 0)})
    fillTween:Play()

    return fillTween
end

local function playGiftAnimation()
    giftBtn.Size = UDim2.new(0, 0, 0, 50) 
    giftBtn.BackgroundTransparency = 0
    gText.Position = UDim2.new(0, 120, 0.5, 0)
    
    giftBtn.Visible = true
    gIcon.ImageTransparency = 0
    gText.TextTransparency = 1 

    TweenService:Create(giftBtn, TweenInfo.new(0.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Size = UDim2.new(0, 200, 0, 50) 
    }):Play()
    
    TweenService:Create(gText, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        Position = UDim2.new(0.5, 15, 0.5, 0),
        TextTransparency = 0
    }):Play()

    local sound = Instance.new("Sound", workspace)
    sound.Name = "GiftEffectSound"
    sound.SoundId = "rbxassetid://14674229054"
    sound.Volume = 2 
    sound.PlayOnRemove = true
    sound:Destroy()

    task.wait(3)

    local closeInfo = TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.In)
    TweenService:Create(giftBtn, closeInfo, {
        Size = UDim2.new(0, 0, 0, 50),
        BackgroundTransparency = 1
    }):Play()
    
    TweenService:Create(gIcon, closeInfo, {ImageTransparency = 1}):Play()
    TweenService:Create(gText, closeInfo, {TextTransparency = 1}):Play()
    
    task.delay(0.4, function()
        if giftBtn.BackgroundTransparency == 1 then
            giftBtn.Visible = false
        end
    end)
end

