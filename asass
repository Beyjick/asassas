local function closeAll()
    if fillTween then fillTween:Cancel() end
    debounce = true
    
    local activeFrame = buyFrame.Visible and buyFrame or (successFrame.Visible and successFrame or nil)
    
    if activeFrame then
        local downPos = UDim2.new(activeFrame.Position.X.Scale, activeFrame.Position.X.Offset, activeFrame.Position.Y.Scale + 0.02, activeFrame.Position.Y.Offset) 
        local fadeOutInfo = TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.In)
        
        TweenService:Create(activeFrame, fadeOutInfo, {
            Position = downPos,
            Size = UDim2.new(0, 440, 0, 220) 
        }):Play()
        fadeGroup(activeFrame, 1, fadeOutInfo)
        
        task.wait(0.25)
        activeFrame.Visible = false
    end
    
    toggleOverlay(false)
    debounce = false
end

