local function formatNumber(n)
    return tostring(math.floor(n)):reverse():gsub("(%d%d%d)", "%1,"):reverse():gsub("^,", "")
end

local function makeDraggable(frame)
    local dragging = false
    local dragInput
    local dragStart
    local startPos

    local function update(input)
        local delta = input.Position - dragStart
        frame.Position = UDim2.new(
            startPos.X.Scale,
            startPos.X.Offset + delta.X,
            startPos.Y.Scale,
            startPos.Y.Offset + delta.Y
        )
    end

    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 
        or input.UserInputType == Enum.UserInputType.Touch then

            dragging = true
            dragStart = input.Position
            startPos = frame.Position

            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)

    frame.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement 
        or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            update(input)
        end
    end)
end

local function createPanel(name, w, h, parent, draggable)
    local f = Instance.new("Frame") 
    f.Name = name
    f.Size = UDim2.new(0, w, 0, h)
    f.AnchorPoint = Vector2.new(0.5, 0.5)
    f.Position = UDim2.new(0.5, 0, 0.5, 0)
    f.BackgroundColor3 = Colors.BgDark
    f.BorderSizePixel = 0
    f.BackgroundTransparency = 0 
    f.ZIndex = 10
    f.Parent = parent

    local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(0, 10); c.Parent = f
    
    if draggable then
        makeDraggable(f)
    end
    
    return f
end

local function fadeGroup(container, targetTransparency, timeInfo)
    TweenService:Create(container, timeInfo, {BackgroundTransparency = targetTransparency}):Play()
    for _, v in pairs(container:GetDescendants()) do
        if v:IsA("TextLabel") or v:IsA("TextBox") then
            TweenService:Create(v, timeInfo, {TextTransparency = targetTransparency}):Play()
        elseif v:IsA("ImageLabel") then
            TweenService:Create(v, timeInfo, {ImageTransparency = targetTransparency}):Play()
        elseif v:IsA("TextButton") then
            TweenService:Create(v, timeInfo, {TextTransparency = targetTransparency}):Play()
            if v.Name == "CloseButton" then
                TweenService:Create(v, timeInfo, {BackgroundTransparency = 1}):Play()
            else
                TweenService:Create(v, timeInfo, {BackgroundTransparency = targetTransparency}):Play()
            end
        elseif v:IsA("Frame") and v.Name == "FillBar" then
            TweenService:Create(v, timeInfo, {BackgroundTransparency = targetTransparency}):Play()
        end
    end
end

local function resetFrameVisuals(frame)
    frame.BackgroundTransparency = 0
    for _, v in pairs(frame:GetDescendants()) do
        if v:IsA("TextLabel") or v:IsA("TextBox") then
            v.TextTransparency = 0
        elseif v:IsA("ImageLabel") then
            v.ImageTransparency = 0
        elseif v:IsA("TextButton") then
            v.TextTransparency = 0
            if v.Name == "CloseButton" then
                v.BackgroundTransparency = 1 
            else
                v.BackgroundTransparency = 0
            end
        elseif v:IsA("Frame") and v.Name == "FillBar" then
            v.BackgroundTransparency = 0
        end
    end
end

